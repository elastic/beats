# ============================== Process Security ==============================
# Disable seccomp system call filtering on Linux.
# Otherwise osquerybeat can't fork osqueryd with the error: Failed to start osqueryd process: fork/exec ./osqueryd: operation not permitted
seccomp.enabled: false
