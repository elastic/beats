# Copy to sf-creds.env (gitignored) and fill in real values for local salesforce_live tests.
# See live_validation_local_test.go and live_activity_helpers_test.go for usage.

SALESFORCE_INSTANCE_URL=https://your-org.my.salesforce.com
SALESFORCE_CLIENT_ID=your-connected-app-consumer-key
SALESFORCE_CLIENT_SECRET=your-connected-app-consumer-secret
SALESFORCE_USERNAME=user@example.com
SALESFORCE_PASSWORD=your-password
SALESFORCE_SECURITY_TOKEN=your-security-token
SALESFORCE_TOKEN_URL=https://login.salesforce.com/services/oauth2/token
